#!/usr/bin/env bash
# Generate the DSNP-contracts spreadsheet from the local DB (loaded with prod data).
#
# Usage:
#   ./generate-dsnp-report                          # all DSNP contracts, up to today
#   ./generate-dsnp-report 2025-11-04               # submitted on/after 2025-11-04
#   ./generate-dsnp-report 2025-11-04 2025-12-31    # submitted within a date range
#   ./generate-dsnp-report 2025-11-04 --by latest   # filter on latest (not initial) submission
#   ./generate-dsnp-report -o ~/Downloads/foo.xlsx  # custom output path (combinable with dates)
#
# Default output: ~/Documents/DSNP_Contracts_in_MC-Review.xlsx
# Relies on DATABASE_URL from the environment (exported by .envrc / direnv).
set -euo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -z "${DATABASE_URL:-}" ]]; then
    echo "DATABASE_URL is not set. Run 'direnv allow' or export it, then retry." >&2
    exit 1
fi

exec python3 "$DIR/generate_dsnp_spreadsheet.py" "$@"
