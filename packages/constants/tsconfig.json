{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "lib": ["ES2021", "DOM"],
        "target": "ES2021",
        "moduleResolution": "bundler",
        "declaration": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "preserveConstEnums": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "jsx": "react",
        "rootDir": "./src",
        "outDir": "build"
    },
    "include": ["src"]
}
