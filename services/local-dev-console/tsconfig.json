{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "module": "ESNext",
        "lib": ["ES2021", "DOM"],
        "target": "ES2021",
        "moduleResolution": "bundler",
        "types": ["vite/client"],
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "jsx": "react-jsx"
    },
    "include": ["src", "vite.config.ts"]
}
