}

enum ArrayFieldOverrideOperation {
  OVERRIDE
  ADD
  DELETE
}

model RateDocumentOverride {
  id                     String                      @id @default(uuid())
  createdAt              DateTime                    @default(now())
  rateRevisionOverrideID String
  rateRevisionOverride   RateRevisionOverrides       @relation(fields: [rateRevisionOverrideID], references: [id], onDelete: Cascade)
  documentOp             ArrayFieldOverrideOperation
  documentSha256         String
  documentID             String?
  document               RateDocument?               @relation(fields: [documentID], references: [id])

  // Add-path payload (set only when documentOp = ADD).
  // All nullable at the DB layer; write-path validator enforces name/sha256/s3URL for adds.
  name         String?
  s3URL        String?
  s3BucketName String?
  s3Key        String?
  sha256       String?

  // Meta data
  dateAdded   DateTime?
  dateAddedOp ScalarFieldOverrideOperation?
}

model RateSupportingDocumentOverride {
  id                     String                      @id @default(uuid())
  createdAt              DateTime                    @default(now())
  rateRevisionOverrideID String
  rateRevisionOverride   RateRevisionOverrides       @relation(fields: [rateRevisionOverrideID], references: [id], onDelete: Cascade)
  documentOp             ArrayFieldOverrideOperation
  documentSha256         String
  documentID             String?
  document               RateSupportingDocument?     @relation(fields: [documentID], references: [id])

  // Add-path payload (set only when documentOp = ADD).
  // All nullable at the DB layer; write-path validator enforces name/sha256/s3URL for adds.
  name         String?
  s3URL        String?
  s3BucketName String?
  s3Key        String?
  sha256       String?

  // Meta data
  dateAdded   DateTime?
  dateAddedOp ScalarFieldOverrideOperation?
}

// Override on a single contract document for a submitted contract revision.
// documentOp controls add/override/delete behavior. documentID is only a relation
// to a base document when the row targets an original submitted-revision document.
model ContractDocumentOverride {
  id                         String                      @id @default(uuid())
  createdAt                  DateTime                    @default(now())
  contractRevisionOverrideID String
  contractRevisionOverride   ContractRevisionOverrides   @relation(fields: [contractRevisionOverrideID], references: [id], onDelete: Cascade)
  documentOp                 ArrayFieldOverrideOperation
  documentSha256             String
  documentID                 String?
  document                   ContractDocument?           @relation(fields: [documentID], references: [id])

  // Add-path payload (set only when documentOp = ADD).
  // All nullable at the DB layer; write-path validator enforces name/sha256/s3URL for adds.
  name         String?
  s3URL        String?
  s3BucketName String?
  s3Key        String?
  sha256       String?

  // Meta data — overrideable in both add and update paths.
  dateAdded   DateTime?
  dateAddedOp ScalarFieldOverrideOperation?
}

// Override on a single contract supporting document for a submitted contract revision.
// Same add vs. update semantics as ContractDocumentOverride.
model ContractSupportingDocumentOverride {
  id                         String                      @id @default(uuid())
  createdAt                  DateTime                    @default(now())
  contractRevisionOverrideID String
  contractRevisionOverride   ContractRevisionOverrides   @relation(fields: [contractRevisionOverrideID], references: [id], onDelete: Cascade)
  documentOp                 ArrayFieldOverrideOperation
  documentSha256             String
  documentID                 String?
  document                   ContractSupportingDocument? @relation(fields: [documentID], references: [id])

  // Add-path payload (set only when documentOp = ADD).
  // All nullable at the DB layer; write-path validator enforces name/sha256/s3URL for adds.
  name         String?
  s3URL        String?
  s3BucketName String?
  s3Key        String?
  sha256       String?

  // Meta data — overrideable in both add and update paths.
  dateAdded   DateTime?
  dateAddedOp ScalarFieldOverrideOperation?
}
